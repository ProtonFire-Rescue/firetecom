---
const badgeText = 'TECNOLOGÍA Y COMUNICACIÓN DE ALTO RENDIMIENTO'

const titleLines = [
  'Comunicación Crítica y',
  'Tecnología de Rescate de',
  'Alto Nivel',
]

const subtitle =
  'Equipamiento robusto y sistemas de comunicación certificados para cuerpos de bomberos e instituciones de seguridad en Ecuador.'
---

<section
  id="inicio"
  class="relative overflow-hidden bg-surface px-6 pb-16 pt-24 md:pb-24 md:pt-32"
  aria-labelledby="hero-heading"
>
  <div class="absolute inset-0 bg-gradient-to-br from-red-500/5 via-transparent to-transparent pointer-events-none"></div>
  <div class="absolute top-20 right-20 w-96 h-96 bg-red-500/10 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-10 left-10 w-64 h-64 bg-red-500/5 rounded-full blur-2xl pointer-events-none"></div>
  
  <div class="mx-auto flex max-w-5xl flex-col items-center text-center relative">
    <!-- Badge -->
    <div
      class="mb-10 inline-flex h-12 items-center gap-3 rounded-full border border-black bg-black px-6 text-[15px] leading-7 text-white md:px-8 animate-fade-in-up shadow-xl shadow-black/20"
      style="animation-delay: 0.1s"
    >
      <span class="size-2.5 shrink-0 rounded-full bg-brand" aria-hidden="true"></span>
      <span class="font-title uppercase tracking-wide">{badgeText}</span>
    </div>

    <!-- Title -->
    <h1
      id="hero-heading"
      class="font-display text-[clamp(2.5rem,6vw,4.0625rem)] leading-[1.05] text-black animate-fade-in-up"
      style="animation-delay: 0.2s"
    >
      {titleLines.map((line, index) => (
        <span class="block animate-fade-in-up" style={`animation-delay: ${0.3 + index * 0.1}s`}>{line}</span>
      ))}
    </h1>

    <!-- Subtitle -->
    <p class="mt-8 max-w-2xl text-lg leading-7 text-black/90 md:text-[18px] md:leading-7 animate-fade-in-up" style="animation-delay: 0.5s">
      {subtitle}
    </p>

    <!-- CTAs -->
    <div class="mt-10 flex flex-col items-stretch gap-4 sm:flex-row sm:items-center sm:justify-center animate-fade-in-up" style="animation-delay: 0.6s">
      <a
        href="#contacto"
        class="font-title inline-flex h-[50px] min-w-[179px] items-center justify-center rounded-full bg-brand px-8 text-base text-white transition-all hover:opacity-90 hover:scale-105 hover:shadow-lg hover:shadow-red-500/30"
      >
        Solicita tu cotización
      </a>
      <a
        href="#productos"
        class="font-title inline-flex h-[50px] min-w-[179px] items-center justify-center rounded-full border border-border-subtle bg-white/40 px-8 text-base text-black backdrop-blur-sm transition-all hover:bg-white/70 hover:scale-105 hover:shadow-lg"
      >
        Explorar productos
      </a>
    </div>

   
  </div>
</section>

<style>
  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in-up {
    animation: fade-in-up 0.8s ease-out forwards;
    opacity: 0;
  }
</style>
