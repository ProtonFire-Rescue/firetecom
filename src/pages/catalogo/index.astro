---
import Layout from "../../layouts/Layout.astro";
import ProductCatalog from "../../components/sections/products/ProductCatalog.tsx";
---

<Layout title="Catálogo">
    <!-- Hero Banner de Productos -->
    <section
        class="relative w-full h-[400px] sm:h-[450px] flex items-center overflow-hidden"
    >
        <!-- Imagen de fondo táctil -->
        <img
            src="/resources/banner_products.png"
            alt="Operaciones tácticas y de rescate Fire Tecom"
            class="absolute inset-0 w-full h-full object-cover brightness-[0.7] animate-scale-ken-burns"
        />
        <!-- Degradado para legibilidad del texto en el lado izquierdo -->
        <div
            class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/30 to-transparent z-0"
        >
        </div>

        <!-- Contenido del Banner -->
        <div
            class="relative z-10 w-full max-w-[1535px] mx-auto px-6 flex flex-col gap-4"
        >
            <h1
                class="font-title text-white text-[clamp(1.8rem,4vw,44px)] leading-[1.15] max-w-3xl animate-fade-in-up"
            >
                Tener el dispositivo correcto marca la diferencia en cada
                operación
            </h1>
            <p
                class="font-text text-white/80 text-sm sm:text-md md:text-lg max-w-xl animate-fade-in-up delay-100"
            >
                Velocidad, agilidad y protección respaldada desde un solo
                equipo.
            </p>
        </div>
    </section>

    <ProductCatalog client:load />
</Layout>

<style>
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes scaleKenBurns {
        from {
            transform: scale(2.05);
        }
        to {
            transform: scale(1);
        }
    }

    .animate-fade-in-up {
        opacity: 0;
        animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .animate-scale-ken-burns {
        animation: scaleKenBurns 1.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .delay-100 {
        animation-delay: 400ms;
    }
</style>
