---
import Layout from "../../layouts/Layout.astro";
import ProductCatalog from "../../components/sections/products/ProductCatalog.tsx";
import {
    getCategories,
    getTypes,
    getProducts,
} from "../../services/fetch";

const fetch_categories = await getCategories({ astro: Astro });
const fetch_types = await getTypes({ astro: Astro });
const fetch_products = await getProducts({ astro: Astro });

const categories = fetch_categories.data.map((category) => category.name);
const types = fetch_types.data.map((type) => type.name);
const products = fetch_products.data.map((product: any) => ({
    id: product.id,
    name: product.name,
    description: product.description,
    category: product.categories[0].name,
    type: product.type.name,
    brand: product.brand.name,
    image: product.images[0].url,
    badge: product.certifications[0].name,
    url: `/catalogo/${product.categories[0].name.toLowerCase().replace(" ", "-")}/${product.name}`,
}));

// Las marcas se derivan de los productos (ya filtrados por Telcom en la API),
// así solo aparecen las marcas realmente asociadas a Telcom — evita depender
// de una relación personal_brands en el content type `brand`.
const brands = [...new Set(products.map((product) => product.brand))]
    .filter(Boolean)
    .sort((a, b) => a.localeCompare(b));
---

<Layout title="Catálogo">
    <!-- Hero Banner de Productos -->
    <section
        class="relative w-full h-[400px] sm:h-[450px] flex items-center overflow-hidden"
    >
        <!-- Imagen de fondo táctil -->
        <img
            src="/resources/banner_products.png"
            alt="Operaciones tácticas y de rescate Fire Tecom"
            class="absolute inset-0 w-full h-full object-cover brightness-[0.7] animate-scale-ken-burns"
        />
        <!-- Degradado para legibilidad del texto en el lado izquierdo -->
        <div
            class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/30 to-transparent z-0"
        >
        </div>

        <!-- Contenido del Banner -->
        <div
            class="relative z-10 w-full max-w-[1535px] mx-auto px-6 flex flex-col gap-4"
        >
            <h1
                class="font-title text-white text-[clamp(1.8rem,4vw,44px)] leading-[1.15] max-w-3xl animate-fade-in-up"
            >
                Tener el dispositivo correcto marca la diferencia en cada
                operación
            </h1>
            <p
                class="font-text text-white/80 text-sm sm:text-md md:text-lg max-w-xl animate-fade-in-up delay-100"
            >
                Velocidad, agilidad y protección respaldada desde un solo
                equipo.
            </p>
        </div>
    </section>

    <ProductCatalog
        client:load
        categories={categories}
        types={types}
        brands={brands}
        products={products}
    />
</Layout>

<style>
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes scaleKenBurns {
        from {
            transform: scale(2.05);
        }
        to {
            transform: scale(1);
        }
    }

    .animate-fade-in-up {
        opacity: 0;
        animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .animate-scale-ken-burns {
        animation: scaleKenBurns 1.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .delay-100 {
        animation-delay: 400ms;
    }
</style>
