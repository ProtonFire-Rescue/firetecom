---
import Layout from '../../../layouts/Layout.astro'
import ProductDetailGallery from '../../../components/sections/products/ProductDetailGallery'
import ProductDetailAccordion from '../../../components/sections/products/ProductDetailAccordion'
import ProductInquiryActions from '../../../components/sections/products/ProductInquiryActions'
import { getProducts } from '../../../services/fetch';

const { tipo, producto } = Astro.params;

const opts = {astro: Astro}

const {data: allProducts} = await getProducts(opts);

const product = allProducts.filter((product: any) => product.name === producto)[0];

const productData = {
  name: product.name,
  marca: product.brand.name,
  modelo: product.model.name,
  tipo: product.type.name,
  description: product.description,
  normas: product.certifications.map((cert: any) => `${cert.name} - ${cert.description}`),
  images: product.images.map((img: any) => `${img.url}`),
}






// Número de WhatsApp de contacto (formato internacional, solo dígitos).
// TODO: reemplazar por el número real de Fire Tecom.
const whatsappNumber = '521234567890'

// URL absoluta del producto, resuelta en el servidor a partir de la petición.
// Se pasa ya formada al componente cliente para que servidor y cliente
// rendericen el mismo href (evita el mismatch de hidratación).
const productPath = `/catalogo/${tipo}/${producto}`
const productUrl = new URL(productPath, Astro.url).href


const relatedProducts = allProducts.filter((p: any) => p.type.name === tipo && p.id !== product.id).slice(0, 3).map((p: any) => ({
  name: p.name,
  description: p.description,
  image: p.images[0].url,
  badge: p.certifications[0].name,
  url: `/catalogo/${tipo}/${producto}`,
}));


// Breadcrumb labels
const tipoLabel = tipo
  ? tipo.charAt(0).toUpperCase() + tipo.slice(1).replace(/-/g, ' ')
  : 'Categoría'
const productoLabel = productData.name

// Descripción para metadatos: primer párrafo del producto.
const metaDescription = Array.isArray(productData.description)
  ? productData.description[0]
  : productData.description

// Datos estructurados Product para resultados enriquecidos en Google.
const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: productData.name,
  description: metaDescription,
  image: productData.images,
  brand: {
    '@type': 'Brand',
    name: productData.marca,
  },
  model: productData.modelo,
  category: productData.tipo,
}
---

<Layout
  title={productData.name}
  description={metaDescription}
  image={productData.images?.[0]}
  jsonLd={productSchema}
>
  <main class="bg-white border border-black">

    <!-- ─── Breadcrumb ───────────────────────────────────────────── -->
    <nav class="px-6 py-3 border-b border-gray-100" aria-label="Breadcrumb">
      <div class="max-w-[1280px] mx-auto flex items-center gap-1.5 text-xs text-gray-500 flex-wrap">
        <a href="/" class="hover:text-brand transition-colors">Home</a>
        <span>/</span>
        <a href="/catalogo" class="hover:text-brand transition-colors">Catálogo</a>
        <span>/</span>
        <a href={`/catalogo?type=${tipo}`} class="hover:text-brand transition-colors capitalize">
          {tipoLabel}
        </a>
        <span>/</span>
        <span class="text-gray-800 font-medium break-all">{productoLabel}</span>
      </div>
    </nav>

    <!-- ─── Product Detail ───────────────────────────────────────── -->
    <section class="px-6 py-8">
      <div class="max-w-[1280px] mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">

          <!-- Left: Gallery -->
          <div class="lg:sticky lg:top-24">
            <ProductDetailGallery
              client:load
              images={productData.images}
              title={productData.name}
            />
          </div>

          <!-- Right: Info -->
          <div class="flex flex-col gap-0">

            <!-- Eyebrow -->
            <span class="reveal text-[11px] font-semibold uppercase tracking-[0.18em] text-brand mb-2" style="--d:0ms">
              {productData.tipo}
            </span>

            <!-- Title -->
            <h1 class="reveal text-2xl sm:text-3xl font-bold text-gray-900 mb-4 leading-tight break-words" style="--d:60ms">
              {productData.name}
            </h1>

            <!-- Meta row: Marca / Modelo / Tipo -->
            <div class="reveal flex flex-wrap gap-3 mb-6" style="--d:120ms">
              {[
                { label: 'Marca', value: productData.marca },
                { label: 'Modelo', value: productData.modelo },
                { label: 'Tipo', value: productData.tipo },
              ].map((m) => (
                <div class="flex flex-col rounded-xl border border-gray-200/70 bg-gray-50/60 px-3.5 py-2">
                  <span class="text-[10px] text-gray-400 uppercase tracking-wider mb-0.5">{m.label}</span>
                  <span class="text-sm font-semibold text-gray-800">{m.value}</span>
                </div>
              ))}
            </div>

            <!-- Accordions -->
            <div class="reveal" style="--d:180ms">
              <ProductDetailAccordion
                client:load
                items={[
                  {
                    label: 'Descripción',
                    content: productData.description,
                    variant: 'paragraphs',
                    defaultOpen: true,
                  },
                  {
                    label: 'Normas y certificaciones',
                    content: productData.normas,
                    defaultOpen: false,
                  },
                ]}
              />
            </div>

            <!-- CTA Buttons -->
            <div class="reveal mt-7 pt-1" style="--d:240ms">
              <ProductInquiryActions
                client:load
                productName={productData.name}
                productModel={productData.modelo}
                productUrl={productUrl}
                whatsappNumber={whatsappNumber}
              />
            </div>

          </div>
        </div>
      </div>
    </section>

    <!-- ─── Otros productos ──────────────────────────────────────── -->
    {
      relatedProducts.length > 0 && <section class="bg-[#1a1a1a] py-14 px-6 mt-8">
      <div class="max-w-[1280px] mx-auto">
        <h2 data-reveal class="text-white text-2xl font-bold mb-8">
          Otros productos que podrían<br class="hidden sm:block"/> interesarte
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {relatedProducts.length >= 1  && relatedProducts.map((p, i) => (
            <div data-reveal style={`transition-delay:${i * 90}ms`} class="flex">
            <a
              href={p.url}
              class="group relative w-full bg-[#242424] rounded-2xl overflow-hidden flex flex-col transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl hover:shadow-black/40"
            >
              <!-- Arrow icon -->
              <div class="absolute top-3 right-3 z-10 w-8 h-8 bg-black/60 rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M3 11L11 3M11 3H5M11 3v6" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>

              <!-- Product image area -->
              <div class="relative bg-zinc-800 aspect-[4/3] flex items-center justify-center p-6">
                <img
                  src={p.image}
                  alt={p.name}
                  class="max-h-full max-w-full object-contain transition-transform duration-500 group-hover:scale-105"
                />
              </div>

              <!-- Info -->
              <div class="p-4 flex flex-col gap-1">
                <h3 class="text-white text-sm font-semibold leading-snug group-hover:text-brand transition-colors">
                  {p.name}
                </h3>
                <p class="text-zinc-400 text-xs leading-relaxed line-clamp-2">
                  {p.description}
                </p>
              </div>
            </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    }
    <!-- ─── Descarga del catálogo ────────────────────────────────── -->
    <section
      class="relative overflow-hidden min-h-[420px] sm:min-h-[520px] lg:min-h-[580px] flex items-center px-6 sm:px-10"
    >
      <!-- Background image -->
      <img
        src="/resources/banner_detail.png"
        alt="Descarga catálogo"
        class="absolute inset-0 w-full h-full object-cover"
      />
      <!-- Overlay -->
      <div class="absolute inset-0 bg-black/10"></div>

      <!-- Content -->
      <div class="relative z-10 w-full py-16 sm:py-24 lg:py-32">
        <div class="max-w-[700px]" data-reveal>
          <h2
            class="text-white text-3xl sm:text-4xl lg:text-5xl leading-tight mb-6 font-title"
          >
            Descarga y accede a nuestro<br class="hidden sm:block" />
            catálogo de productos que te<br class="hidden sm:block" />
            ofrecemos.
          </h2>
          <a
            href="#"
            id="btn-descargar-catalogo"
            class="group py-3 px-8 bg-black text-white rounded-full inline-flex gap-2 items-center transition-all duration-300 hover:bg-[#1a1a1a] hover:scale-105 hover:shadow-lg hover:shadow-black/30"
          >
            Descargar
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="transition-transform duration-300 group-hover:translate-x-1">
              <path d="M7 2v7m0 0L4 6.5M7 9l3-2.5M2 12h10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </section>

  </main>
</Layout>

<style>
  /* Entrada escalonada de la columna de info (arriba del pliegue) */
  .reveal {
    opacity: 0;
    animation: revealUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: var(--d, 0ms);
  }

  /* Reveal on-scroll para secciones inferiores */
  [data-reveal] {
    opacity: 0;
    transform: translateY(26px);
    transition:
      opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }
  [data-reveal].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @keyframes revealUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal,
    [data-reveal] {
      animation: none !important;
      transition: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>

<script>
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          io.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12, rootMargin: "0px 0px -8% 0px" }
  );
  document.querySelectorAll("[data-reveal]").forEach((el) => io.observe(el));
</script>
