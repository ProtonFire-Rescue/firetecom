---
import Layout from "../layouts/Layout.astro";
import ContactForm from "../components/ContactForm.tsx";
import ContactInfo from "../components/ContactInfo.tsx";
---

<Layout
    title="Contacto"
    description="¿Necesitas equipamiento táctico o de comunicación crítica? Contáctanos y un asesor de Fire Tecom te ayudará a encontrar la solución adecuada para tu operación."
>
    <section class="grid grid-cols-2 h-auto">
        <div class="w-full h-full flex justify-center items-center py-20">
            <ContactForm client:only="react" />
        </div>
        <div
            class="h-full flex items-center justify-center relative overflow-hidden"
        >
            <img
                src="./resources/bgcall.png"
                alt=""
                class="absolute inset-0 object-cover brightness-60 h-full w-full animate-scale-ken-burns"
            />
            <ContactInfo client:only="react" />
        </div>
    </section>
</Layout>

<style>
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes scaleKenBurns {
        from {
            transform: scale(2.05);
        }
        to {
            transform: scale(1);
        }
    }

    .animate-fade-in-up {
        opacity: 0;
        animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .animate-scale-ken-burns {
        animation: scaleKenBurns 1.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .delay-100 {
        animation-delay: 400ms;
    }
</style>
